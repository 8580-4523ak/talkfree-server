rules_version = '2';
// TalkFree — paths must match FirestoreUserService / server (NOT top-level `calls`).
//
// COMMON MISTAKE (Firebase Console): Do NOT use top-level
//   match /call_history/{callId} { ... request.auth.uid == uid }
// Here `uid` is NOT a path variable — only `callId` exists, so rules break / deny.
// The app uses NESTED collections under each user:
//   users/{userId}/call_history/{callSid}
//   users/{userId}/messages/{messageId}
//
// Client reads:
//   - users/{uid}
//   - users/{uid}/call_history
//   - users/{uid}/messages
// Call history rows are written by the Node server (Admin SDK) from Twilio webhooks.

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Own profile + optional lookup by email (see syncUserWithFirestoreOnLogin).
      // Email branch supports the rare `where('email', isEqualTo: …)` lookup on sign-in.
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        (request.auth.token.email != null &&
          resource.data.email == request.auth.token.email)
      );
      allow create: if request.auth != null && request.auth.uid == userId;
      // Premium + balances: only Firebase Admin / Node (verified Razorpay, grant-reward, billing).
      allow update: if request.auth != null && request.auth.uid == userId
        && request.resource.data.isPremium == resource.data.isPremium
        && request.resource.data.subscription_tier == resource.data.subscription_tier
        && request.resource.data.premium_plan_type == resource.data.premium_plan_type
        && request.resource.data.credits == resource.data.credits
        && request.resource.data.paidCredits == resource.data.paidCredits
        && request.resource.data.rewardCredits == resource.data.rewardCredits
        && request.resource.data.last_razorpay_payment_id == resource.data.last_razorpay_payment_id
        && request.resource.data.premiumWelcomeBonusGranted == resource.data.premiumWelcomeBonusGranted
        && request.resource.data.number_expiry_date == resource.data.number_expiry_date
        && request.resource.data.premium_subscribed_at == resource.data.premium_subscribed_at
        && request.resource.data.totalOutboundCalls == resource.data.totalOutboundCalls
        && request.resource.data.totalCallTalkSeconds == resource.data.totalCallTalkSeconds
        && request.resource.data.welcomeCallingCreditsGranted == resource.data.welcomeCallingCreditsGranted
        && request.resource.data.ad_streak_count == resource.data.ad_streak_count
        && request.resource.data.ad_streak_last_day == resource.data.ad_streak_last_day;
      allow delete: if request.auth != null && request.auth.uid == userId;

      match /call_history/{callSid} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      match /messages/{messageId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }
  }
}
