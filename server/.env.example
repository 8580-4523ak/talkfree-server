# Copy to .env next to index.js and fill in real values.

# Public URL of this server (Twilio voice + SMS webhooks). No trailing slash — otherwise
# URLs become https://host//sms-webhook and Twilio can reject or mis-route requests.
# Render example: https://your-service.onrender.com
PUBLIC_BASE_URL=https://talkfree-server.onrender.com

# Twilio wallet: each US local number is ~US$1.15/mo; concurrent "Claim" = one purchase per user.
# Keep a few dollars in the account if multiple users may provision at once.

# REST API (outbound calls via GET /call or POST /call with JSON, Twilio client)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# E.164 caller ID for Voice + fallback `From` for POST /send-sms when user has no assigned_number.
TWILIO_CALLER_ID=+1xxxxxxxxxx

# Flutter Voice SDK — GET /token (JWT)
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=your_api_key_secret
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

PORT=3000

# Razorpay (TalkFree Pro) — Orders API + POST /verify-payment (HMAC). Key secret NEVER in the Flutter app.
# RAZORPAY_KEY_ID=rzp_test_xxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
# RAZORPAY_CURRENCY=INR

# Browse-number flow: POST /purchase-browse-number (must match Flutter VirtualNumber.defaultPrice).
# BROWSE_NUMBER_PRICE=500

# Welcome bonus credits when POST /verify-payment first grants Pro (default 1000).
# PREMIUM_WELCOME_BONUS=1000

# Firebase Admin JSON (single line) — required for POST /grant-reward, POST /assign-number, POST /send-sms, POST /admin/upgrade-user.
# Paste the full service account JSON from Firebase Console → Project settings → Service accounts.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# POST /admin/upgrade-user — long random string; send as header X-Admin-Secret or Authorization: Bearer …
# (for payment webhooks later). Never commit the real value.
# ADMIN_SECRET_KEY=your-long-random-secret
# Optional override for bonus credits (default 1000).
# ADMIN_UPGRADE_BONUS_CREDITS=1000

# Credits added per successful POST /grant-reward — one rewarded ad = one grant (default 2).
# REWARD_GRANT_CREDITS=2

# POST /claim-welcome-bonus — one-time welcome credits (paid bucket; default 10).
# WELCOME_LOGIN_BONUS=10

# Outbound call billing: free tier (default 10) vs premium tier (default 7) — see POST /call-live-tick & settlement.
# CALL_CREDITS_PER_MINUTE=10
# CALL_CREDITS_PER_MINUTE_PREMIUM=7

# POST /assign-number — Twilio search + purchase. Eligible: isPremium OR lifetime ads_watched_count ≥ ASSIGN_NUMBER_MIN_ADS_WATCHED (credits alone do not unlock).
# JSON body: { "planType": "daily"|"weekly"|"monthly"|"yearly" } — credits deducted + number_expiry_date set.
# Premium users pay 0 credits but still pick a plan for lease duration.
# PLAN_DAILY_CREDITS=50
# PLAN_WEEKLY_CREDITS=200
# PLAN_MONTHLY_CREDITS=700
# PLAN_YEARLY_CREDITS=5000
# PLAN_DAILY_MS=86400000
# PLAN_WEEKLY_MS=604800000
# PLAN_MONTHLY_MS=2592000000
# PLAN_YEARLY_MS=31536000000
# ASSIGN_NUMBER_MIN_CREDITS=100
# ASSIGN_NUMBER_MIN_ADS_WATCHED=50
#
# Optional US area code (NPA) for available-number search, e.g. 415. If set, search is limited to
# that area; if unset, Twilio returns numbers from the broader US local inventory (not “one fixed”
# area — pool depends on Twilio availability).
# ASSIGN_NUMBER_AREA_CODE=415
#
# US SMS (A2P / 10DLC): Twilio may require brand/campaign registration before inbound SMS delivers.
# If messages are not received, check Twilio Console → Messaging / Trust Hub / Messaging Policy.
#
# Inbound SMS webhook (must be reachable on the public internet): {PUBLIC_BASE_URL}/sms-webhook
# The server responds 200 with empty TwiML so Twilio knows the webhook succeeded (no error loop).

# Nightly job: release Twilio numbers whose number_expiry_date is in the past (saves ~$1.15/mo per number).
# Cron is UTC. Set DISABLE_NUMBER_JANITOR=1 to skip (e.g. local dev).
# NUMBER_JANITOR_CRON=0 4 * * *
# DISABLE_NUMBER_JANITOR=1
