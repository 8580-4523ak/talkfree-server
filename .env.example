# Flutter app: copy to project root as `.env` (see .gitignore).
#
# Voice API base URL is fixed in lib/config/voice_backend_config.dart:
# https://talkfree-server.onrender.com

# Twilio — used by client-side helpers (SMS tests, etc.). Prefer backend for production.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_CALLER_ID=+1xxxxxxxxxx

# Optional: TwiML Bin URL if calling Twilio directly from app (legacy / testing)
TWILIO_VOICE_TWIML_URL=https://handler.twilio.com/twiml/EHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
