# Copy to `.env` in the project root and fill in your values.
# The real `.env` file is gitignored.
#
# VoIP access token server (Node server in /server). No Twilio secrets in the app.
# Emulator: http://10.0.2.2:3000  |  Device: http://YOUR_LAN_IP:3000  |  Prod: https://...
VOICE_BACKEND_BASE_URL=http://10.0.2.2:3000
#
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
# Outbound voice: TwiML Bin URL (Console → TwiML Bins → copy URL, e.g. https://handler.twilio.com/twiml/EH...)
TWILIO_VOICE_TWIML_URL=https://handler.twilio.com/twiml/EHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# TwiML Bin body (Create bin → paste XML → Save → copy bin URL into TWILIO_VOICE_TWIML_URL above):
# <Response>
#   <Dial callerId="+1XXXXXXXXXX">
#     <Number>{{To}}</Number>
#   </Dial>
# </Response>
# Use the same E.164 as TWILIO_PHONE_NUMBER for callerId (your Twilio number). {{To}} is the callee from the API call.
