# Flutter app: copy to project root as `.env` (see .gitignore).
#
# Voice API base URL is fixed in lib/config/voice_backend_config.dart:
# https://talkfree-server.onrender.com

# Razorpay Checkout — Key ID from https://dashboard.razorpay.com → API Keys (use rzp_test_… for sandbox).
# Amounts in app: INR = paise, USD = cents (see lib/screens/subscription_screen.dart).
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
# Optional: INR (default) or USD — must match your Razorpay account currency.
# RAZORPAY_CURRENCY=INR

# Twilio credentials live only on the Node server — do not add them here.
